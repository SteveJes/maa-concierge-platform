# Core
NODE_ENV=development
LOG_LEVEL=info
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_ORG_ID=<OPTIONAL>
OPENAI_MODEL=gpt-4.1-mini

# Web app
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_DEFAULT_TENANT=maa

# API
API_PORT=4000
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000

# Integrations
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
NOCO_API_URL=http://localhost:8080
NOCO_API_TOKEN=<YOUR_NOCO_TOKEN>
NOCO_TABLE_TENANTS=tenants
NOCO_TABLE_SOURCES=sources
NOCO_TABLE_DOCUMENTS=documents
NOCO_TABLE_INGESTION_RUNS=ingestion_runs
CALENDLY_URL=https://calendly.com/example
VAPI_ASSISTANT_ID=<OPTIONAL>
