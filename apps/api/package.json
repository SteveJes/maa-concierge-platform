{
  "name": "@platform/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "tunnel": "ngrok http 4000",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:maa:web": "tsx src/scripts/ingest-maa-web.ts",
    "ingest:maa:web:smoke": "tsx src/scripts/ingest-maa-web.ts --smoke",
    "discover:maa": "tsx src/scripts/discover-maa.ts",
    "generate:maa:approved-sources": "tsx src/scripts/generate-approved-sources-maa.ts",
    "ingest:maa:pdf": "tsx src/scripts/ingest-maa-pdf.ts",
    "index:maa:documents": "tsx src/scripts/index-maa-documents.ts",
    "search:maa:knowledge": "tsx src/scripts/search-maa-knowledge.ts",
    "test:maa:chat": "tsx src/scripts/test-maa-chat.ts",
    "test:maa:pricing": "tsx src/scripts/test-maa-pricing-regression.ts",
    "test:maa:schedule": "tsx src/scripts/test-maa-schedule-regression.ts",
    "test:maa:policy": "tsx src/scripts/test-maa-policy-regression.ts",
    "test:maa:callback": "tsx src/scripts/test-maa-callback-regression.ts",
    "test:maa:calendly": "tsx src/scripts/test-maa-calendly-regression.ts",
    "test:maa:followup": "tsx src/scripts/test-maa-followup-regression.ts",
    "test:maa:chat:followup": "tsx src/scripts/test-maa-chat-followup-regression.ts",
    "test:maa:vapi": "tsx src/scripts/test-maa-vapi-regression.ts",
    "test:maa:phone:routing": "tsx src/scripts/test-maa-phone-routing-regression.ts",
    "test:maa:auto": "tsx src/scripts/test-maa-autonomous-regression.ts",
    "vapi:debug:latest": "tsx src/scripts/vapi-debug-latest.ts",
    "vapi:debug:latest:json": "tsx src/scripts/vapi-debug-latest.ts --json",
    "vapi:debug:audio-latency": "tsx src/scripts/vapi-debug-audio-latency.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@platform/agent-runtime": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/retrieval": "workspace:*",
    "@platform/schemas": "workspace:*",
    "dotenv": "^17.4.0",
    "fastify": "^5.2.0",
    "langfuse": "^3.38.20",
    "stripe": "^22.1.0",
    "unpdf": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.0",
    "vitest": "^4.1.5"
  }
}
