{
  "name": "@platform/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "node -e \"console.log('lint placeholder: api')\"",
    "test": "node -e \"console.log('test placeholder: api')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ingest:maa:web": "tsx src/scripts/ingest-maa-web.ts",
    "ingest:maa:web:smoke": "tsx src/scripts/ingest-maa-web.ts --smoke"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@platform/agent-runtime": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/retrieval": "workspace:*",
    "@platform/schemas": "workspace:*",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.0"
  }
}
