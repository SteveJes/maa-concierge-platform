{
  "name": "@platform/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
  "dev": "tsx watch src/index.ts",
  "build": "tsc -p tsconfig.json",
  "start": "node dist/index.js",
  "lint": "eslint .",
  "typecheck": "tsc -p tsconfig.json --noEmit",
  "ingest:maa:web": "tsx src/scripts/ingest-maa-web.ts",
  "ingest:maa:web:smoke": "tsx src/scripts/ingest-maa-web.ts --smoke",
  "discover:maa": "tsx src/scripts/discover-maa.ts",
  "generate:maa:approved-sources": "tsx src/scripts/generate-approved-sources-maa.ts",
  "ingest:maa:pdf": "tsx src/scripts/ingest-maa-pdf.ts",
  "index:maa:documents": "tsx src/scripts/index-maa-documents.ts"
},
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@platform/agent-runtime": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/retrieval": "workspace:*",
    "@platform/schemas": "workspace:*",
    "fastify": "^5.2.0",
    "unpdf": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.0"
  }
}
